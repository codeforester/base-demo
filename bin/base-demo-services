#!/usr/bin/env python3
"""Service lifecycle command for the base-demo representative environment."""

from __future__ import annotations

import argparse
import json
import os
import signal
import shlex
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


def project_root() -> Path:
    root = os.environ.get("BASE_PROJECT_ROOT")
    if root:
        return Path(root).resolve()
    return Path(__file__).resolve().parents[1]


def load_catalog(path: Path) -> list[dict[str, Any]]:
    try:
        with path.open(encoding="utf-8") as handle:
            payload = json.load(handle)
    except FileNotFoundError:
        raise SystemExit(f"ERROR: service catalog not found: {path}") from None
    except json.JSONDecodeError as exc:
        raise SystemExit(f"ERROR: service catalog is not valid JSON: {exc}") from None

    services = payload.get("services")
    if not isinstance(services, list):
        raise SystemExit("ERROR: service catalog must contain a services array.")
    return services


def load_environment(root: Path, name: str) -> dict[str, Any]:
    path = root / "environments" / f"{name}.json"
    try:
        with path.open(encoding="utf-8") as handle:
            payload = json.load(handle)
    except FileNotFoundError:
        raise ValueError(f"environment not found: {name}") from None
    except json.JSONDecodeError as exc:
        raise ValueError(f"environment {name} is not valid JSON: {exc}") from None
    return payload


def compose_file(root: Path) -> Path:
    return root / "infra" / "compose.yaml"


def compose_service_names(services: list[dict[str, Any]]) -> list[str]:
    names: list[str] = []
    for service in services:
        compose_name = service.get("compose_service")
        if isinstance(compose_name, str) and compose_name:
            names.append(compose_name)
    return names


def process_services(services: list[dict[str, Any]]) -> list[dict[str, Any]]:
    return [
        service
        for service in services
        if (service.get("lifecycle") or {}).get("type") == "process"
    ]


def process_command(service: dict[str, Any]) -> list[str]:
    lifecycle = service.get("lifecycle") or {}
    command = lifecycle.get("command")
    if not isinstance(command, list) or not all(isinstance(item, str) for item in command):
        raise ValueError(f"{service.get('name', '-')}: process lifecycle command must be a string array")
    return command


def state_dir(root: Path) -> Path:
    configured = os.environ.get("BASE_DEMO_SERVICES_STATE_DIR")
    if configured:
        return Path(configured).resolve()
    return root / "var" / "services"


def process_state_path(root: Path, service: dict[str, Any]) -> Path:
    return state_dir(root) / f"{service.get('name', 'service')}.json"


def process_log_path(root: Path, service: dict[str, Any]) -> Path:
    return state_dir(root) / f"{service.get('name', 'service')}.log"


def read_process_state(root: Path, service: dict[str, Any]) -> dict[str, Any] | None:
    path = process_state_path(root, service)
    try:
        with path.open(encoding="utf-8") as handle:
            payload = json.load(handle)
    except (FileNotFoundError, json.JSONDecodeError):
        return None
    return payload if isinstance(payload, dict) else None


def process_is_running(pid: int | None) -> bool:
    if not pid:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def compose_command(root: Path, args: list[str]) -> list[str]:
    return [
        "docker",
        "compose",
        "-f",
        str(compose_file(root)),
        "-p",
        "base-demo",
        *args,
    ]


def run_compose(root: Path, args: list[str]) -> int:
    command = compose_command(root, args)
    if os.environ.get("BASE_DEMO_SERVICES_DRY_RUN") == "1":
        print(f"DRY-RUN {shlex.join(command)}")
        return 0
    if shutil.which("docker") is None:
        print("ERROR: docker is not available; cannot manage Compose services.", file=sys.stderr)
        return 2
    return subprocess.run(command, check=False).returncode


def start_process(service: dict[str, Any], root: Path) -> int:
    name = str(service.get("name", "-"))
    try:
        command = process_command(service)
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2
    if os.environ.get("BASE_DEMO_SERVICES_DRY_RUN") == "1":
        print(f"DRY-RUN start {name}: {shlex.join(command)}")
        return 0

    state = read_process_state(root, service)
    pid = state.get("pid") if state else None
    if isinstance(pid, int) and process_is_running(pid):
        print(f"{name} already running pid={pid}")
        return 0

    directory = state_dir(root)
    directory.mkdir(parents=True, exist_ok=True)
    log_path = process_log_path(root, service)
    env = os.environ.copy()
    env["BASE_PROJECT_ROOT"] = str(root)
    port = service.get("port")
    if port is not None:
        env["PORT"] = str(port)

    with log_path.open("ab") as log_handle:
        process = subprocess.Popen(
            command,
            cwd=root,
            env=env,
            stdout=log_handle,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
    state_payload = {
        "pid": process.pid,
        "started_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "command": command,
        "log": str(log_path),
    }
    with process_state_path(root, service).open("w", encoding="utf-8") as handle:
        json.dump(state_payload, handle, indent=2)
        handle.write("\n")
    print(f"{name} started pid={process.pid}")
    return 0


def stop_process(service: dict[str, Any], root: Path) -> int:
    name = str(service.get("name", "-"))
    if os.environ.get("BASE_DEMO_SERVICES_DRY_RUN") == "1":
        print(f"DRY-RUN stop {name}")
        return 0
    state_path = process_state_path(root, service)
    state = read_process_state(root, service)
    pid = state.get("pid") if state else None
    if not isinstance(pid, int) or not process_is_running(pid):
        if state_path.exists():
            state_path.unlink()
        print(f"{name} stopped")
        return 0

    os.kill(pid, signal.SIGTERM)
    for _ in range(20):
        if not process_is_running(pid):
            break
        time.sleep(0.1)
    if process_is_running(pid):
        os.kill(pid, signal.SIGKILL)
    if state_path.exists():
        state_path.unlink()
    print(f"{name} stopped")
    return 0


def check_service(service: dict[str, Any], root: Path) -> tuple[bool, str]:
    check = service.get("check") or {"type": "none"}
    check_type = check.get("type")

    if check_type == "none":
        return True, "none"

    if check_type == "file":
        path_value = check.get("path")
        if not isinstance(path_value, str) or not path_value:
            return False, "file:<missing path>"
        path = Path(path_value)
        if not path.is_absolute():
            path = root / path
        return path.exists(), f"file:{path_value}"

    if check_type == "http":
        url = service.get("health_url")
        if not isinstance(url, str) or not url:
            return False, "http:<missing health_url>"
        try:
            with urllib.request.urlopen(url, timeout=1.0) as response:
                return 200 <= response.status < 400, f"http:{url}"
        except (OSError, urllib.error.URLError) as exc:
            return False, f"http:{url} ({exc})"

    if check_type == "compose":
        service_name = check.get("service") or service.get("compose_service") or service.get("name")
        if not isinstance(service_name, str) or not service_name:
            return False, "compose:<missing service>"
        if shutil.which("docker") is None:
            return False, f"compose:{service_name} unavailable"
        command = compose_command(root, ["ps", "--services", "--status", "running"])
        result = subprocess.run(command, check=False, capture_output=True, text=True)
        running = set(result.stdout.splitlines())
        return service_name in running, f"compose:{service_name}"

    return False, f"unsupported:{check_type}"


def health_label(service: dict[str, Any]) -> str:
    check = service.get("check") or {"type": "none"}
    if service.get("health_url"):
        return str(service["health_url"])
    if check.get("type") == "compose":
        return f"compose:{check.get('service', service.get('compose_service', '-'))}"
    if check.get("type") == "file":
        return f"file:{check.get('path', '-')}"
    return str(check.get("type") or "-")


def service_rows(services: list[dict[str, Any]], root: Path) -> list[dict[str, str]]:
    rows: list[dict[str, str]] = []
    for service in services:
        ok, detail = check_service(service, root)
        state = "healthy" if ok else "unhealthy"
        if not ok and not service.get("required", False):
            state = "stopped"
        since = "-"
        process_state = read_process_state(root, service)
        if process_state:
            started_at = process_state.get("started_at")
            if isinstance(started_at, str) and started_at:
                since = started_at
        rows.append(
            {
                "name": str(service.get("name", "-")),
                "kind": str(service.get("kind", "-")),
                "runtime": str(service.get("runtime", "-")),
                "port": str(service.get("port") or "-"),
                "health": health_label(service),
                "state": state,
                "since": since,
                "logs": str(service.get("logs") or "-"),
                "detail": detail,
                "required": "true" if service.get("required", False) else "false",
            }
        )
    return rows


def print_table(rows: list[dict[str, str]]) -> None:
    headers = ("NAME", "KIND", "RUNTIME", "PORT", "HEALTH", "STATE", "SINCE", "LOGS")
    keys = ("name", "kind", "runtime", "port", "health", "state", "since", "logs")
    widths = {
        key: max(len(header), *(len(row[key]) for row in rows)) if rows else len(header)
        for key, header in zip(keys, headers)
    }
    print("  ".join(header.ljust(widths[key]) for key, header in zip(keys, headers)))
    for row in rows:
        print("  ".join(row[key].ljust(widths[key]) for key in keys))


def cmd_status(services: list[dict[str, Any]], root: Path, environment: dict[str, Any]) -> int:
    env_name = str(environment.get("name", "dev"))
    print(f"environment={env_name}")
    print(f"mode={environment.get('mode', 'operational')}")
    rows = service_rows(services, root)
    if not rows:
        print("No services configured.")
        return 0
    print_table(rows)
    return 0


def cmd_check(services: list[dict[str, Any]], root: Path) -> int:
    failed = False
    for row in service_rows(services, root):
        if row["state"] == "healthy":
            print(f"{row['name']} ok")
            continue
        if row["required"] == "true":
            print(f"{row['name']} fail {row['detail']}")
            failed = True
        else:
            print(f"{row['name']} skip optional {row['detail']}")
    return 1 if failed else 0


def cmd_lifecycle(services: list[dict[str, Any]], root: Path, action: str) -> int:
    if action == "restart":
        stop_result = cmd_lifecycle(services, root, "stop")
        start_result = cmd_lifecycle(services, root, "start")
        return stop_result or start_result

    result = 0
    compose_names = compose_service_names(services)
    if compose_names:
        if action == "start":
            result = run_compose(root, ["up", "-d", *compose_names])
        if action == "stop":
            result = run_compose(root, ["down"])

    for service in process_services(services):
        if action == "start":
            process_result = start_process(service, root)
            result = result or process_result
        if action == "stop":
            process_result = stop_process(service, root)
            result = result or process_result
    return result


def cmd_logs(services: list[dict[str, Any]], root: Path) -> int:
    result = 0
    compose_names = compose_service_names(services)
    if compose_names:
        result = run_compose(root, ["logs", "--tail", "50", *compose_names])
    for service in process_services(services):
        name = service.get("name", "-")
        log_path = process_log_path(root, service)
        if os.environ.get("BASE_DEMO_SERVICES_DRY_RUN") == "1":
            print(f"DRY-RUN logs {name}: {log_path}")
            continue
        if not log_path.exists():
            print(f"{name} logs unavailable")
            continue
        print(f"==> {name} {log_path} <==")
        print(log_path.read_text(encoding="utf-8")[-4000:], end="")
    return result


def parse_args(argv: list[str]) -> argparse.Namespace:
    root = project_root()
    parser = argparse.ArgumentParser(description="Manage base-demo representative services.")
    parser.add_argument("--catalog", default=str(root / "services" / "catalog.json"))
    parser.add_argument("--env", default="dev")
    parser.add_argument("command", choices=("status", "start", "stop", "restart", "check", "logs"))
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])
    root = project_root()
    try:
        environment = load_environment(root, args.env)
    except ValueError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 2
    services = load_catalog(Path(args.catalog))

    if args.command == "status":
        return cmd_status(services, root, environment)
    if args.command == "check":
        return cmd_check(services, root)
    if args.command in {"start", "stop", "restart"}:
        return cmd_lifecycle(services, root, args.command)
    if args.command == "logs":
        return cmd_logs(services, root)

    raise AssertionError(f"unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
