{
  "version": 1,
  "services": [
    {
      "name": "project-baseline",
      "kind": "project",
      "runtime": "base",
      "port": null,
      "health_url": null,
      "required": true,
      "check": {
        "type": "file",
        "path": "base_manifest.yaml"
      },
      "logs": null
    },
    {
      "name": "postgres",
      "kind": "database",
      "runtime": "compose",
      "port": 5432,
      "health_url": null,
      "required": false,
      "compose_service": "postgres",
      "check": {
        "type": "compose",
        "service": "postgres"
      },
      "logs": "docker compose logs postgres"
    },
    {
      "name": "mysql",
      "kind": "database",
      "runtime": "compose",
      "port": 3306,
      "health_url": null,
      "required": false,
      "compose_service": "mysql",
      "check": {
        "type": "compose",
        "service": "mysql"
      },
      "logs": "docker compose logs mysql"
    },
    {
      "name": "redis",
      "kind": "cache",
      "runtime": "compose",
      "port": 6379,
      "health_url": null,
      "required": false,
      "compose_service": "redis",
      "check": {
        "type": "compose",
        "service": "redis"
      },
      "logs": "docker compose logs redis"
    },
    {
      "name": "go-api",
      "kind": "service",
      "runtime": "docker",
      "port": 8010,
      "health_url": "http://127.0.0.1:8010/healthz",
      "required": false,
      "compose_service": "go-api",
      "check": {
        "type": "http"
      },
      "logs": "docker compose logs go-api"
    }
  ]
}
